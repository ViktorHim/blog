{
    "name": "blog",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "eslint": "eslint .",
        "eslint:fix": "eslint --fix .",
        "style-lint": "stylelint \"**/*.scss\"",
        "style-lint:fix": "stylelint --fix \"**/*.scss\"",
